# Compiled binaries / shared objects
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binaries and coverage output
*.test
*.out
coverage.txt
coverage.html

# Local build artifacts
/bin/
/dist/

# Command binaries — `go build .` inside a cmd dir emits one named after the
# dir. Built into a container image (Dockerfile) or with -o, never committed.
/cmd/disco/disco

# Example binaries — `go build ./...` inside an example dir emits one named
# after the dir. Built standalone in CI/e2e with -o, never committed.
/examples/discovery/discovery
/examples/multi-node/multi-node
/examples/single-node/single-node
/build/

# go.work is committed deliberately: the library + every standalone example
# module share one workspace for the dev loop. CI/e2e build with GOWORK=off to
# prove standalone resolution. (See CONTRIBUTING → "Adding an example".)

# IDE / editor cruft
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Local config / secrets
.env
.env.*
*.local

# Claude Code local state
.claude/
